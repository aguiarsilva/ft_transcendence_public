{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "esModuleInterop": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": false,
    "strict": true,
    "outDir": "./dist",
    "skipLibCheck": true,
  },
  "include": ["src/**/*.ts", "src/services"]
}
